{
  "name": "StoreConfig",
  "type": "object",
  "properties": {
    "store_name": {
      "type": "string",
      "description": "Nome da loja"
    },
    "logo_url": {
      "type": "string",
      "description": "URL do logo da loja"
    },
    "banner_url": {
      "type": "string",
      "description": "URL do banner principal"
    },
    "primary_color": {
      "type": "string",
      "default": "#E53E3E",
      "description": "Cor principal da loja"
    },
    "phone": {
      "type": "string",
      "description": "Telefone da loja"
    },
    "address": {
      "type": "string",
      "description": "Endere\u00e7o da loja"
    },
    "delivery_fee": {
      "type": "number",
      "default": 5.0,
      "description": "Taxa de entrega"
    },
    "min_order": {
      "type": "number",
      "default": 20.0,
      "description": "Pedido m\u00ednimo"
    },
    "estimated_delivery_time": {
      "type": "string",
      "default": "30-50 min",
      "description": "Tempo estimado de entrega"
    },
    "is_open": {
      "type": "boolean",
      "default": true,
      "description": "Loja aberta ou fechada"
    },
    "opening_hours": {
      "type": "string",
      "description": "Hor\u00e1rio de funcionamento"
    },
    "pix_key": {
      "type": "string",
      "description": "Chave PIX para pagamento"
    },
    "accepts_card": {
      "type": "boolean",
      "default": true
    },
    "accepts_cash": {
      "type": "boolean",
      "default": true
    },
    "accepts_pix": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "store_name"
  ]
}   